# Backend — Environment Variables
# Copy this file to .env and fill in values for local development
# NEVER commit the real .env file

SECRET_KEY=django-insecure-local-only-change-this
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Local Docker Postgres (used when DATABASE_URL is not set)
POSTGRES_DB=legal_office_db
POSTGRES_USER=admin
POSTGRES_PASSWORD=supersecurepassword123
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Production Neon DB (leave blank for local dev)
# DATABASE_URL=postgresql://user:pass@host/dbname?sslmode=require

# ── S3 / Supabase File Storage ─────────────────────────────────────────────
# Set USE_S3=True in production to store hearing documents in Supabase S3.
# Leave blank (or False) for local Docker disk storage.
USE_S3=False
# SUPABASE_S3_ACCESS_KEY=
# SUPABASE_S3_SECRET_KEY=
# SUPABASE_S3_BUCKET_NAME=
# SUPABASE_S3_ENDPOINT=https://<project-ref>.supabase.co/storage/v1/s3
# SUPABASE_S3_REGION=ap-southeast-1   # match your Supabase project region

# ── CORS ───────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3002
